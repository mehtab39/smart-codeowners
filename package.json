{
  "name": "smart-codeowners",
  "version": "0.1.0",
  "description": "Smart CODEOWNERS generator based on git commit history with recency weighting",
  "main": "dist/index.js",
  "bin": {
    "smart-codeowners": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "codeowners",
    "git",
    "github",
    "code-ownership",
    "cli"
  ],
  "author": "Mehtab Singh Gill",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mehtab39/smart-codeowners.git"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "simple-git": "^3.22.0",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
